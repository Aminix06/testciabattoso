task.spawn(function()
	repeat task.wait() until game:IsLoaded()
	
	local function IsPublicServer()
		local jobId = game.JobId
		local placeId = game.PlaceId
		local cursor = ""
		while true do
			local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?limit=100&cursor=" .. cursor
			local requestFunc = (syn and syn.request) or (http and http.request) or http_request or request
			if not requestFunc then return true end
			local success, response = pcall(function() return requestFunc({Url = url, Method = "GET"}) end)
			if not success or not response or response.StatusCode ~= 200 then
				task.wait(1)
			else
				local data = HttpService:JSONDecode(response.Body)
				for _, server in ipairs(data.data) do
					if server.id == jobId then return true end
				end
				cursor = data.nextPageCursor
				if not cursor then break end
			end
			task.wait(0.1)
		end
		return false
	end

	if IsPublicServer() then
		localPlayer:Kick("SEI IN UN SERVER PUBBLICO! Kick di sicurezza attivato.")
	else
		print("🔒 Server Privato confermato.")
        local TPEvent = ReplicatedStorage:WaitForChild("Package"):WaitForChild("Events"):WaitForChild("TP")
		
		local function CheckIntruders()
			if #Players:GetPlayers() > 1 then
                warn("⚠️ Intruso rilevato! Eseguo Server Hop...")
				TPEvent:InvokeServer("Earth") 
			end
		end

		CheckIntruders()
		Players.PlayerAdded:Connect(CheckIntruders)
	end
end)

