local function ApplyFloat(char)
    local root = char:WaitForChild("HumanoidRootPart", 5)
    if root then
        for _, child in pairs(root:GetChildren()) do
            if child.Name == "FloatAttachment" or child.Name == "FloatVelocity" then child:Destroy() end
        end
        local att = Instance.new("Attachment", root)
        att.Name = "FloatAttachment"
        local lv = Instance.new("LinearVelocity", root)
        lv.Name = "FloatVelocity"
        lv.Attachment0 = att
        lv.MaxForce = math.huge
        lv.VectorVelocity = Vector3.new(0, 0, 0)
        lv.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
        lv.ForceLimitMode = Enum.ForceLimitMode.PerAxis
        lv.MaxAxesForce = Vector3.new(0, math.huge, 0) 
    end
end
