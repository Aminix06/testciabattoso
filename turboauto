-- AUTO REFRESH SERVER 6000 SECONDI
-- ==============================================================================
task.spawn(function()
	local PlaceId = game.PlaceId
	local TPEvent = ReplicatedStorage:WaitForChild("Package"):WaitForChild("Events"):WaitForChild("TP")

    local TimerScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    TimerScreenGui.DisplayOrder = 999
    local TimerFrame = Instance.new("Frame", TimerScreenGui)
    TimerFrame.Size = UDim2.new(0, 220, 0, 40)
    TimerFrame.Position = UDim2.new(0.5, -110, 0, -48)
    TimerFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    TimerFrame.BackgroundTransparency = 0.4
    local UICorner = Instance.new("UICorner", TimerFrame)
    UICorner.CornerRadius = UDim.new(0, 8)
    local TimerLabel = Instance.new("TextLabel", TimerFrame)
    TimerLabel.Size = UDim2.new(1, 0, 1, 0)
    TimerLabel.BackgroundTransparency = 1
    TimerLabel.Font = Enum.Font.FredokaOne
    TimerLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    TimerLabel.TextScaled = true

	if (getgenv().FarmTarget == "EARTH" and PlaceId == 3311165597) or (getgenv().FarmTarget == "TOP" and PlaceId == 114014249462644) then
		local timeLeft = 6000

		while timeLeft > 0 do
            task.wait(1)
            
            if getgenv().IsSwitching then
                TimerScreenGui.Enabled = false
            else
                TimerScreenGui.Enabled = true
                timeLeft = timeLeft - 1
                TimerLabel.Text = "Farm " .. getgenv().FarmTarget .. ". TP Refresh in: " .. timeLeft .. "s"
            end
		end

		TimerScreenGui.Enabled = true
		TimerLabel.Text = "Refresh Server in corso..."
        
        if getgenv().FarmTarget == "EARTH" then
            TPEvent:InvokeServer("T.O.P") 
        else
            TPEvent:InvokeServer("Earth")
        end
	end
end)
