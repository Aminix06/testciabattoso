local function StartTheGame()
    local playerGui = localPlayer:WaitForChild("PlayerGui")
    local mainGui = playerGui:WaitForChild("Main", 10)
    if not mainGui then return end
    task.wait()
    local Event = ReplicatedStorage.Package.Events.Start
    Event:InvokeServer()
    task.wait()
    Event:InvokeServer()
    task.wait()
    local bruhButton = mainGui:FindFirstChild("bruh")
    if bruhButton then
        bruhButton.Disabled = true
        bruhButton.Disabled = false
    end
    task.wait()
    Event:InvokeServer()
end
StartTheGame()
