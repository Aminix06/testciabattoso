    sg.DisplayOrder = 1000

    local MainFrame = Instance.new("Frame", sg)
    MainFrame.Size = UDim2.new(0, 240, 0, 280)
    MainFrame.Position = UDim2.new(1, -260, 0.5, -140)
    MainFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    MainFrame.BackgroundTransparency = 0.15 
    MainFrame.Active = true

    local mainCorner = Instance.new("UICorner", MainFrame)
    mainCorner.CornerRadius = UDim.new(0, 12)
    
    local mainStroke = Instance.new("UIStroke", MainFrame)
    mainStroke.Color = Color3.fromRGB(255, 255, 255)
    mainStroke.Thickness = 2
    local strokeGradient = Instance.new("UIGradient", mainStroke)
    strokeGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 204)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 150, 255))
    }

    local dragging, dragInput, mousePos, framePos
    MainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            mousePos = input.Position
            framePos = MainFrame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    MainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - mousePos
            MainFrame.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
        end
    end)

    local Title = Instance.new("TextLabel", MainFrame)
    Title.Size = UDim2.new(1, 0, 0, 45)
    Title.BackgroundTransparency = 1
    Title.Font = Enum.Font.FredokaOne
    Title.Text = "⚡ CIAB PANEL ⚡"
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextScaled = true

    local BossContainer = Instance.new("Frame", MainFrame)
    BossContainer.Size = UDim2.new(1, -20, 1, -55)
    BossContainer.Position = UDim2.new(0, 10, 0, 45)
    BossContainer.BackgroundTransparency = 1

    local scroll = Instance.new("ScrollingFrame", BossContainer)
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = Color3.fromRGB(0, 255, 204)
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.BorderSizePixel = 0
    
    local listLayout = Instance.new("UIListLayout", scroll)
    listLayout.Padding = UDim.new(0, 8)
    listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local bossNamesList = {"Universal Vegito", "Goheta (Base - SSJB)", "Fused Zamasu"}
    
    for _, bossName in ipairs(bossNamesList) do
        local btn = Instance.new("TextButton", scroll)
        btn.Size = UDim2.new(1, -10, 0, 42)
        btn.Font = Enum.Font.FredokaOne
        btn.Text = bossName
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextScaled = true
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

        local function UpdateColor()
            local targetColor = getgenv().BossTargets[bossName] and Color3.fromRGB(0, 170, 80) or Color3.fromRGB(180, 40, 40)
            TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = targetColor}):Play()
        end
        
        btn.BackgroundColor3 = getgenv().BossTargets[bossName] and Color3.fromRGB(0, 170, 80) or Color3.fromRGB(180, 40, 40)

        btn.MouseButton1Click:Connect(function()
            getgenv().BossTargets[bossName] = not getgenv().BossTargets[bossName]
            UpdateColor()
            SaveConfig()
        end)
    end

    listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y)
    end)
end
CreateUnifiedGUI()

