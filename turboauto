    while true do
        if localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid") and localPlayer.Character.Humanoid.Health > 0 then
            for bossName, isToggled in pairs(getgenv().BossTargets) do
                if isToggled then
                    CheckAndFightBoss(bossName)
                end
            end
        end
        task.wait(0.5)
    end
end)
