local BossConfig = {
    ["Universal Vegito"] = {QuestNPC = "Universal Vegito", BossName = "Universal Vegito", Distance = -3},
    ["Goheta (Base - SSJB)"] = {QuestNPC = "Goheta (Base - SSJB)", BossName = "Goheta (Base - SSJB)", Distance = -3},
    ["Fused Zamasu"] = {QuestNPC = "Fused Zamasu", BossName = "Fused Zamasu", Distance = -3}
}

local function TeleportAndFight(bossData)
    local camera = workspace.CurrentCamera
	local function getValidBoss()
        local character = localPlayer.Character
		if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then return nil end

		local bossModel = workspace.Living:FindFirstChild(bossData.BossName)
		if not (bossModel and bossModel.Parent) then return nil end

		local bossHumanoid = bossModel:FindFirstChildOfClass("Humanoid")
		local bossHRP = bossModel:FindFirstChild("HumanoidRootPart")

		if bossHumanoid and bossHRP and bossHumanoid.Health > 0 then
			return bossModel 
		end
		return nil
	end

	while true do
        if not getgenv().BossTargets[bossData.BossName] then break end
		local currentBoss = getValidBoss()
		if not currentBoss then break end

		local bossHRP = currentBoss.HumanoidRootPart 
        local character = localPlayer.Character
        local hrp = character:FindFirstChild("HumanoidRootPart")

		pcall(function()
			camera.CFrame = CFrame.new(camera.CFrame.Position, bossHRP.Position)
			local behindOffset = bossHRP.CFrame.LookVector * bossData.Distance
			local behindPosition = bossHRP.Position + behindOffset
			hrp.CFrame = CFrame.new(behindPosition, bossHRP.Position)
		end)

		pcall(function()
            local Events = ReplicatedStorage:WaitForChild("Package"):WaitForChild("Events")
            local attackRemote = Events:WaitForChild("FaFa")
                    
            Events.p:FireServer("Blacknwhite27", 1)

            task.spawn(function() attackRemote:InvokeServer("Meteor Crash", "Blacknwhite27") end)
            task.spawn(function() attackRemote:InvokeServer("Wolf Fang Fist", "Blacknwhite27") end)
            task.spawn(function() attackRemote:InvokeServer("Mach Kick", "Blacknwhite27") end)
            task.spawn(function() attackRemote:InvokeServer("God Slicer", "Blacknwhite27") end)
            task.spawn(function() attackRemote:InvokeServer("Super Dragon Fist", "Blacknwhite27") end)
		end)

		task.wait(0.05)
	end

	pcall(function()
		camera.CameraType = Enum.CameraType.Custom
		camera.CameraSubject = localPlayer.Character.Humanoid
	end)
end

local function WaitForBossToSpawn(bossData, timeLimit)
	local startTime = os.time()
	local bossReady = false
 
	repeat
        local char = localPlayer.Character
        if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then return end
        if not getgenv().BossTargets[bossData.BossName] then return end 

		task.wait(0.2) 
		local boss = workspace.Living:FindFirstChild(bossData.BossName)
		bossReady = boss and boss:FindFirstChild("HumanoidRootPart") and boss:FindFirstChild("Humanoid") and boss.Humanoid.Health > 0
	until bossReady or os.time() - startTime > timeLimit 
 
	if bossReady then
        task.wait(0.2)
		TeleportAndFight(bossData)
	end
end

local function CheckAndFightBoss(bossName)
    local bossData = BossConfig[bossName]
    if not bossData then return end
    
    local character = localPlayer.Character
    if not character or not character:FindFirstChild("Humanoid") or character.Humanoid.Health <= 0 then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local playerData = ReplicatedStorage.Datas:FindFirstChild(tostring(localPlayer.UserId))
    if not playerData or not hrp then return end

    -- 1. Controlla se l'NPC della quest ESISTE realmente sulla mappa
    local bossNpc = workspace.Others.NPCs:FindFirstChild(bossData.QuestNPC)
    
    -- 2. Se l'NPC esiste, cerca di prendere la quest (solo per max 5 secondi)
    if bossNpc and bossNpc:FindFirstChild("HumanoidRootPart") then
        local startTime = os.time()
        while playerData:WaitForChild("Quest").Value ~= bossData.BossName do
            if os.time() - startTime > 5 then break end -- Non bloccarsi per più di 5 sec
            if not getgenv().BossTargets[bossName] then return end
            if not localPlayer.Character or localPlayer.Character.Humanoid.Health <= 0 then return end

            hrp.CFrame = bossNpc.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3)
            pcall(function() ReplicatedStorage.Package.Events:WaitForChild("Qaction"):InvokeServer(bossNpc) end)
            task.wait(0.5)
        end
    end

    -- 3. A prescindere dalla quest (che l'abbia presa o che non esista), aspetta il boss e picchialo
    -- Aspetta massimo 5 secondi che compaia, se non compare passa subito al prossimo boss
    WaitForBossToSpawn(bossData, 5) 
end

