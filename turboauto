local ConfigName = "CiabTurboConfig.json"

local DefaultBosses = {
    ["Universal Vegito"] = true,
    ["Goheta (Base - SSJB)"] = true,
    ["Fused Zamasu"] = true
}

if isfile and isfile(ConfigName) then
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(ConfigName))
    end)
    if success and data then
        getgenv().BossTargets = data.BossTargets or {}
        for boss, val in pairs(DefaultBosses) do
            if getgenv().BossTargets[boss] == nil then
                getgenv().BossTargets[boss] = val
            end
        end
    else
        getgenv().BossTargets = DefaultBosses
    end
else
    getgenv().BossTargets = DefaultBosses
    if writefile then
        writefile(ConfigName, HttpService:JSONEncode({BossTargets = DefaultBosses}))
    end
end

local function SaveConfig()
    if writefile then
        writefile(ConfigName, HttpService:JSONEncode({
            BossTargets = getgenv().BossTargets
        }))
    end
end

